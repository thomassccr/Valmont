//@version=5
// =============================================================================
//  Thomas | Highs & Lows 1H / 4H
// -----------------------------------------------------------------------------
//  Trace le HIGH et le LOW de chaque bougie cloturee en 1H et en 4H sous forme
//  de lignes horizontales avec un label ("1h High", "1h Low", "4h High"...).
//
//  Les niveaux sont recuperes via request.security : ils restent donc affiches
//  quel que soit le timeframe du graphique. Tu peux descendre en 15m / 5m / 1m,
//  les highs & lows des bougies 1H et 4H continuent d'etre traces.
//
//  Mitigation : quand un niveau est balaye par le prix, la ligne est soit
//  figee au point de balayage (et estompee), soit supprimee.
// =============================================================================
indicator("Thomas | Highs & Lows 1H / 4H", overlay = true, max_lines_count = 500, max_labels_count = 500)

// ============================== INPUTS =======================================
g1 = "1H"
show1h  = input.bool(true,  "Afficher 1H",                        group = g1)
n1h     = input.int(6,      "Nombre de bougies 1H a garder",      minval = 1, maxval = 100, group = g1)
c1hHi   = input.color(color.new(color.white, 0),  "Couleur High 1H", group = g1, inline = "c1")
c1hLo   = input.color(color.new(color.white, 0),  "Couleur Low 1H",  group = g1, inline = "c1")

g4 = "4H"
show4h  = input.bool(true,  "Afficher 4H",                        group = g4)
n4h     = input.int(6,      "Nombre de bougies 4H a garder",      minval = 1, maxval = 100, group = g4)
c4hHi   = input.color(color.new(color.orange, 0), "Couleur High 4H", group = g4, inline = "c4")
c4hLo   = input.color(color.new(color.orange, 0), "Couleur Low 4H",  group = g4, inline = "c4")

gS = "Style"
showLbl   = input.bool(true,    "Afficher les labels",   group = gS)
lineWidth = input.int(1,        "Epaisseur des lignes",  minval = 1, maxval = 5, group = gS)
styleStr  = input.string("Solid", "Style de ligne", options = ["Solid", "Dashed", "Dotted"], group = gS)

gM = "Mitigation (niveaux balayes)"
mitigate     = input.bool(true,     "Arreter les lignes balayees",                                group = gM)
mitigateMode = input.string("Figer", "Action quand balaye", options = ["Figer", "Supprimer"],     group = gM)
sweepBasis   = input.string("Meche", "Balayage sur",        options = ["Meche", "Cloture"],        group = gM)
fadeSwept    = input.bool(true,     "Estomper les lignes figees",                                  group = gM)

lineStyle = styleStr == "Dashed" ? line.style_dashed : styleStr == "Dotted" ? line.style_dotted : line.style_solid

// ============================== TYPE =========================================
type Lvl
    line   ln
    label  lb
    float  price
    bool   isHigh
    bool   active
    int    bornBar
    color  col

// ============================== HELPER =======================================
// Gere l'ensemble des niveaux pour un timeframe donne.
// Les variables `var` sont persistantes et propres a chaque site d'appel,
// donc un appel par TF garde ses propres tableaux.
manageTF(simple string tf, simple bool show, simple int maxN, color colHi, color colLo, string tag) =>
    var array<Lvl> levels = array.new<Lvl>()

    // Valeurs de la DERNIERE bougie cloturee (non repaint) + son heure d'ouverture.
    [htfHigh, htfLow, htfTime] = request.security(syminfo.tickerid, tf, [high[1], low[1], time[1]], lookahead = barmerge.lookahead_on)

    isNewClose = ta.change(htfTime) != 0

    // ----- Creation d'un nouveau High + Low a chaque cloture HTF -----
    if show and isNewClose and not na(htfHigh)
        lnH = line.new(x1 = htfTime, y1 = htfHigh, x2 = time, y2 = htfHigh, xloc = xloc.bar_time, color = colHi, width = lineWidth, style = lineStyle)
        lbH = label.new(x = time, y = htfHigh, xloc = xloc.bar_time, text = showLbl ? tag + " High" : "", textcolor = colHi, style = label.style_none, size = size.small)
        array.push(levels, Lvl.new(lnH, lbH, htfHigh, true,  true, bar_index, colHi))

        lnL = line.new(x1 = htfTime, y1 = htfLow, x2 = time, y2 = htfLow, xloc = xloc.bar_time, color = colLo, width = lineWidth, style = lineStyle)
        lbL = label.new(x = time, y = htfLow, xloc = xloc.bar_time, text = showLbl ? tag + " Low" : "", textcolor = colLo, style = label.style_none, size = size.small)
        array.push(levels, Lvl.new(lnL, lbL, htfLow, false, true, bar_index, colLo))

        // On ne garde que les maxN*2 derniers objets (maxN highs + maxN lows).
        while array.size(levels) > maxN * 2
            old = array.shift(levels)
            line.delete(old.ln)
            label.delete(old.lb)

    // ----- Mise a jour + detection de balayage (a chaque barre) -----
    basisHi = sweepBasis == "Cloture" ? close : high
    basisLo = sweepBasis == "Cloture" ? close : low

    if array.size(levels) > 0
        for i = array.size(levels) - 1 to 0
            lv = array.get(levels, i)
            if lv.active
                swept = mitigate and bar_index > lv.bornBar and (lv.isHigh ? basisHi > lv.price : basisLo < lv.price)
                if swept
                    line.set_x2(lv.ln, time)
                    label.set_x(lv.lb, time)
                    if mitigateMode == "Supprimer"
                        line.delete(lv.ln)
                        label.delete(lv.lb)
                        array.remove(levels, i)
                    else
                        lv.active := false
                        if fadeSwept
                            line.set_color(lv.ln, color.new(lv.col, 65))
                            line.set_style(lv.ln, line.style_dashed)
                            label.set_text(lv.lb, "")
                else
                    // Toujours active : on prolonge jusqu'au bord droit.
                    line.set_x2(lv.ln, time)
                    label.set_x(lv.lb, time)

// ============================== APPELS =======================================
manageTF("60",  show1h, n1h, c1hHi, c1hLo, "1h")
manageTF("240", show4h, n4h, c4hHi, c4hLo, "4h")
